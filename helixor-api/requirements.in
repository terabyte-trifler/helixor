# =============================================================================
# helixor-api/requirements.in — direct, pinned production dependencies.
#
# VULN-25 SUPPLY CHAIN — see helixor-oracle/requirements.in for the
# full policy. TL;DR:
#   - Every line is an EXACT version pin (`pkg==X.Y.Z`).
#   - Regenerate `requirements.txt` (with sha256 hashes) by running
#     `bash scripts/regen_requirements.sh` from the repo root.
#   - Production deploys run
#       pip install --require-hashes -r helixor-api/requirements.txt
# =============================================================================

# FastAPI HTTP framework + ASGI server.
fastapi==0.136.3
