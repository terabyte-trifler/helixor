# =============================================================================
# /etc/phylanx/oracle-node-0.env  (TEMPLATE — do NOT commit secrets)
#
# One file per cluster node, indexed 0..4. Pinned settings here; secrets
# (the node keypair) are loaded by path from a sealed location.
# =============================================================================

# ── Required: the network. Day-30 guard refuses mainnet without OPT_OK.
PHYLANX_NETWORK=devnet
# PHYLANX_MAINNET_OK=1    # uncomment ONLY for a deliberate mainnet start

# ── VULN-18: scoring determinism pin.
# The oracle process must run on a Python interpreter in the audited set
# (currently 3.12 or 3.13 — see phylanx-oracle/scoring/determinism.py for
# the live SUPPORTED_PYTHON_VERSIONS constant). The guard refuses to
# start on mainnet against a non-pinned runtime; the PHYLANX_SCORING
# _DETERMINISM_OK=1 escape hatch exists ONLY for a CVE-driven emergency
# bypass — record the justification in
# audit/reports/scoring_determinism_optin.md before setting it.
# PHYLANX_SCORING_DETERMINISM_OK=1   # DO NOT set without audit trail.

# ── Required: this node's identity within the cluster.
PHYLANX_NODE_ID=oracle-node-0
PHYLANX_PORT=50051

# Peers — comma-separated id=host:port. In production these are 5 different
# region pubkeys; for a local 5-node cluster these are localhost ports.
PHYLANX_PEERS=oracle-node-1=10.0.1.1:50051,oracle-node-2=10.0.2.1:50051,oracle-node-3=10.0.3.1:50051,oracle-node-4=10.0.4.1:50051

# ── Required: where to find this node's Ed25519 signing keypair. The
# keypair is created out-of-band via solana-keygen, stored at the path
# below with mode 0400 owned by `phylanx`, and its pubkey published in
# the on-chain OracleConfig.cluster_keys + IssuerConfig.cluster_keys.
PHYLANX_KEYPAIR_PATH=/etc/phylanx/keys/oracle-node-0.json

# ── Solana RPC endpoint (used for on-chain reads and submits).
SOLANA_RPC_URL=https://api.devnet.solana.com

# ── gRPC peer transport security.
# Devnet/local clusters may omit these and use plaintext localhost/private
# links. Mainnet oracle nodes refuse to start without all three; the gRPC
# server requires client cert auth and clients validate peers against this CA.
PHYLANX_GRPC_TLS_CERT=/etc/phylanx/tls/oracle-node-0.crt
PHYLANX_GRPC_TLS_KEY=/etc/phylanx/tls/oracle-node-0.key
PHYLANX_GRPC_TLS_CA_CERT=/etc/phylanx/tls/cluster-ca.crt

# ── Kafka / event bus.
#
# VULN-17: production oracle nodes refuse to start without an
# encrypted+authenticated Kafka client. The eventbus.kafka_security
# guard rejects PLAINTEXT and SASL_PLAINTEXT on mainnet-beta unless
# PHYLANX_KAFKA_PLAINTEXT_OK=1 is set (a conscious, audited opt-in for
# the rare deployment behind a private-link service mesh that already
# authenticates the connection).
#
# The recommended production protocol is SASL_SSL + SCRAM-SHA-256.
# The username/password are provisioned out of band; on this host they
# live in /etc/phylanx/kafka/{username,password} (mode 0400) and are
# loaded into the env by the systemd ExecStartPre hook.
#
KAFKA_BOOTSTRAP=10.0.0.10:9093,10.0.0.11:9093,10.0.0.12:9093
KAFKA_CONSUMER_GROUP=oracle-cluster-prod
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=SCRAM-SHA-256
KAFKA_SASL_USERNAME=oracle-node-0
# KAFKA_SASL_PASSWORD is NEVER stored in this template. Operator loads
# it via ExecStartPre from a sealed file; see launch/RUNBOOK.md.
# KAFKA_SASL_PASSWORD=<loaded-at-start>
KAFKA_SSL_CA_LOCATION=/etc/phylanx/kafka/ca.crt
# Optional client mTLS — when set, the SCRAM credential is augmented
# with a client-cert pinning. Omit if the cluster uses SCRAM alone.
# KAFKA_SSL_CERTIFICATE_LOCATION=/etc/phylanx/kafka/oracle-node-0.crt
# KAFKA_SSL_KEY_LOCATION=/etc/phylanx/kafka/oracle-node-0.key
# PHYLANX_KAFKA_PLAINTEXT_OK=1   # DO NOT set on a public network.

# ── TimescaleDB.
DATABASE_URL=postgres://phylanx_oracle:CHANGE_ME@db.internal/phylanx

# ── Observability.
LOG_LEVEL=INFO
METRICS_PORT=9090
SENTRY_DSN=

# ── Misc.
PYTHONUNBUFFERED=1
