    "@types/node":       "^20.12.0",
    "@types/pg":         "^8.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser":        "^7.0.0",
    "bs58":              "^5.0.0",
    "eslint":            "^8.57.0",
    "pg":                "^8.11.5",
    "tsx":               "^4.7.0",
    "typescript":        "^5.4.5"
  }
}
