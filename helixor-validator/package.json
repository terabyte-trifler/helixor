{
  "name": "@helixor/validation",
  "version": "0.14.0",
  "private": true,
  "description": "48h devnet validation — 5 agents with profiled behaviour, machine-checkable PASS/FAIL.",
  "license": "MIT",
  "scripts": {
    "stage":        "tsx scripts/stage_validation.ts",
    "monitor":      "tsx scripts/monitor_validation.ts",
    "inject-tx":    "tsx scripts/inject_tx.ts",
    "verify":       "tsx scripts/verify_validation.ts",
    "report":       "tsx scripts/build_report.ts",
    "teardown":     "tsx scripts/teardown_validation.ts",
    "run-full":     "tsx scripts/run_full_validation.ts",
    "typecheck":    "tsc --noEmit",
    "lint":         "eslint scripts helpers --max-warnings 0"
  },
  "engines": { "node": ">=18" },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@helixor/client":   "file:../helixor-sdk",
