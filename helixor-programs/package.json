{
  "name": "helixor-programs",
  "version": "0.2.0",
  "description": "Helixor Protocol — AI agent trust scoring (Day 2)",
  "license": "MIT",
  "scripts": {
    "build":            "anchor build",
    "test":             "anchor test",
    "test:local":       "anchor test --provider.cluster localnet",
    "test:devnet":      "anchor test --provider.cluster devnet --skip-deploy",
    "test:register":    "anchor test --provider.cluster localnet --run register_agent",
    "deploy:devnet":    "anchor deploy --provider.cluster devnet",
    "lint":             "cargo clippy -- -D warnings",
    "fmt":              "cargo fmt --all",
    "fmt:check":        "cargo fmt --all -- --check",
    "audit":            "cargo audit",
    "clean":            "anchor clean && rm -rf target/ node_modules/"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/web3.js":   "^1.91.1"
  },
  "devDependencies": {
    "@types/bn.js":  "^5.1.5",
    "@types/chai":   "^4.3.14",
    "@types/mocha":  "^10.0.6",
    "@types/node":   "^20.12.5",
    "chai":          "^4.4.1",
    "mocha":         "^10.4.0",
    "ts-mocha":      "^10.0.0",
    "ts-node":       "^10.9.2",
    "typescript":    "^5.4.5"
  }
}
